# Copy this file to lmm_rollout_project/configs/deploy/lmm_deploy.env and edit values.
# Do not commit tokens, passwords, or private paths.

# SSH aliases or user@host entries from ~/.ssh/config.
# Examples seen locally may include ltu or nci-ltu for NVIDIA.
NVIDIA_RENDER_HOST="ltu"

# AMD server is usually reached through VS Code Tunnel, not SSH.
# Set to "ssh" only if SSH becomes available.
AMD_TRAIN_CONNECT_MODE="tunnel"
AMD_TRAIN_HOST=""

# Remote workspace roots. These directories will be created if missing.
NVIDIA_RENDER_ROOT="/scratch/$USER/longhorizon"
AMD_TRAIN_ROOT="/scratch/$USER/longhorizon"

# Optional SSH options. Keep empty unless needed.
SSH_OPTS=""

# rsync behavior.
# Default sync is code/docs/configs/scripts only; heavy data is excluded.
RSYNC_DELETE=0
SYNC_CHECKPOINTS=0
SYNC_DATASETS=0
SYNC_OUTPUTS=0

# Run remote bootstrap after sync. Keep 0 for first dry run/preflight.
DEPLOY_BOOTSTRAP=0

# NVIDIA render host bootstrap controls.
# RUN_B1K_SETUP may install Python deps and BEHAVIOR eval deps using the champion setup script.
INSTALL_SYSTEM_DEPS=0
RUN_B1K_SETUP=0
CHECK_DOCKER_FOR_ISAAC=1

# AMD training host bootstrap controls.
# Current Sana setup script is CUDA-oriented. Use ROCm-specific setup only after confirming ROCm/PyTorch stack.
RUN_ROCM_TORCH_INSTALL=0
ROCM_TORCH_INDEX="https://download.pytorch.org/whl/rocm6.4"
CONDA_ENV_LMM="lmm"

# AMD Slurm reservation.
AMD_SLURM_RESERVATION="gpu-4_gpu-16_gpu-18_gpu-21_gpu-22_gpu-23_gpu-28_gpu-29_reservation"
AMD_SLURM_ALLOC_CMD="salloc --reservation=${AMD_SLURM_RESERVATION} --exclusive --mem=0"

# Optional environment tokens. Prefer exporting these in your shell instead of writing them here.
# HF_TOKEN=""
# WANDB_API_KEY=""
